---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
---

<BaseLayout title="Page not found" description="This page could not be found." noIndex>
  <div class="not-found">
    <div class="container">
      <div class="not-found__content">
        <h1 class="not-found__heading">Page not found</h1>
        <p class="not-found__text">The page you're looking for doesn't exist or has been moved.</p>
        <div class="not-found__actions">
          <Button href="/green-galaxy" variant="primary" label="Go home" />
          <Button href="/green-galaxy/contact" variant="secondary" label="Contact me" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }

  .not-found__content {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .not-found__heading {
    font-size: var(--text-3xl);
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    letter-spacing: -0.05em;
  }

  .not-found__text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .not-found__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
