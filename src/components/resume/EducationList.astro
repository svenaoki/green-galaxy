---
import type { EducationEntry } from "../../data/resume.data";

export interface Props {
  entries: EducationEntry[];
}
---

<div class="education">
  {Astro.props.entries.map((entry) => (
    <article class="education__item">
      <div class="education__header">
        <h3 class="education__qualification">{entry.qualification}</h3>
        <p class="education__dates">{entry.startDate} — {entry.endDate}</p>
      </div>
      <p class="education__institution">{entry.institution}</p>
    </article>
  ))}
</div>

<style>
  .education__item {
    padding-bottom: var(--space-6);
  }

  .education__item:not(:last-child) {
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--space-6);
  }

  .education__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-2);
  }

  @media (min-width: 768px) {
    .education__header {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .education__qualification {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .education__dates {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .education__institution {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }
</style>
