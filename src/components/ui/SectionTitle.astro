---
export interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "left" } = Astro.props;
---

<div class:list={["section-title", `section-title--${align}`]}>
  <h2 class="section-title__heading">{title}</h2>
  {subtitle && <p class="section-title__subtitle">{subtitle}</p>}
</div>

<style>
  .section-title {
    margin-bottom: var(--space-8);
  }

  .section-title--center {
    text-align: center;
  }

  .section-title__heading {
    font-size: var(--text-2xl);
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
    letter-spacing: -0.04em;
  }

  @media (min-width: 768px) {
    .section-title__heading {
      font-size: var(--text-3xl);
    }
  }

  .section-title__subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 540px;
  }

  .section-title--center .section-title__subtitle {
    margin-left: auto;
    margin-right: auto;
  }
</style>
