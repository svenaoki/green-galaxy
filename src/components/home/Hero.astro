---
import { home } from "../../data/home";
import Button from "../ui/Button.astro";
---

<section class="hero section">
  <div class="container container--wide">
    <div class="hero__content">
      <p class="hero__eyebrow">{home.hero.greeting}</p>
      <h1 class="hero__name">{home.hero.role}</h1>
      <p class="hero__description">{home.hero.description}</p>
      <div class="hero__actions">
        <Button href="green-galaxy/resume" variant="primary" label="View resume" size="lg" />
        <Button href="green-galaxy/contact" variant="secondary" label="Get in touch" size="lg" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
    }
  }

  .hero__content {
    max-width: 820px;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    margin-bottom: var(--space-5);
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
  }

  .hero__eyebrow::before {
    content: "";
    width: 0.75rem;
    height: 0.75rem;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    box-shadow: 0 0 0 0.35rem var(--color-accent-soft);
  }

  .hero__name {
    font-size: clamp(2.75rem, 7vw, 5.25rem);
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
    max-width: 880px;
    letter-spacing: -0.06em;
  }

  .hero__description {
    font-size: clamp(1.125rem, 2vw, 1.35rem);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 620px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
